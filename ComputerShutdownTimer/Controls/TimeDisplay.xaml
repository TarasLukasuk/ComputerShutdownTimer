<UserControl x:Class="ComputerShutdownTimer.Controls.TimeDisplay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <Style x:Key="TimeTextStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <Style x:Key="SeparatorStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
    </UserControl.Resources>
    <Viewbox>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
            <TextBlock Text="00" Style="{StaticResource TimeTextStyle}"/>
            <TextBlock x:Name="SeparatorLeft" Text=":" Style="{StaticResource SeparatorStyle}"/>
            <TextBlock Text="00" Style="{StaticResource TimeTextStyle}"/>
            <TextBlock x:Name="SeparatorRight" Text=":" Style="{StaticResource SeparatorStyle}"/>
            <TextBlock Text="00" Style="{StaticResource TimeTextStyle}"/>
        </StackPanel>
    </Viewbox>
</UserControl>

<Window x:Name="window" x:Class="ComputerShutdownTimer.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Shutdown Timer" Height="450" Width="800" WindowStyle="None" Background="Transparent" AllowsTransparency="True">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Resources/Styles/RoundButton.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <Grid>
        <Border CornerRadius="20" Background="#2C3E50">
            <Grid>
                <Border VerticalAlignment="Top" CornerRadius="20,20,0,0" Height="50" Background="#8E44AD" Padding="10">
                    <Grid>
                        <TextBlock Text="Shutdown Timer" Foreground="White" FontSize="20" FontWeight="Bold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <CheckBox/>
                            <Button Style="{StaticResource RoundButton}">
                                
                            </Button>
                            <Button Style="{StaticResource RoundButton}">

                            </Button>
                            <Button Style="{StaticResource RoundButton}">

                            </Button>
                            <Button Style="{StaticResource RoundButton}">

                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>
                <Grid Margin="10,60,10,10">

                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
